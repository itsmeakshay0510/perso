{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores the learned habits, goals, and preferences of the user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "habits": { "type": "array", "items": { "type": "string" }, "description": "Learned recurring behaviors." },
        "goals": { "type": "array", "items": { "type": "string" }, "description": "User-defined or AI-inferred goals." },
        "preferences": { "type": "object", "description": "UI/UX or interaction preferences." },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["uid"]
    },
    "Memory": {
      "title": "Memory",
      "description": "A single interaction or piece of information remembered by the AI.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "content": { "type": "string", "description": "The text content of the memory." },
        "embedding": { "type": "array", "items": { "type": "number" }, "description": "Vector embedding for semantic search." },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["conversation", "fact", "insight"], "description": "The category of memory." },
        "importance": { "type": "number", "description": "A score from 0-1 indicating how critical this memory is." }
      },
      "required": ["uid", "content", "timestamp"]
    },
    "DailySummary": {
      "title": "Daily Summary",
      "description": "A summary of the user's day generated by the AI.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "date": { "type": "string", "format": "date" },
        "summary": { "type": "string" },
        "insights": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "date", "summary"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile data."
    },
    "/users/{uid}/memories/{memoryId}": {
      "schema": "Memory",
      "description": "Individual memories for semantic retrieval."
    },
    "/users/{uid}/summaries/{summaryId}": {
      "schema": "DailySummary",
      "description": "Daily AI-generated summaries."
    }
  }
}
