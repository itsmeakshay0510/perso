rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: /users/{uid} (UserProfile)
    // Collection: /users/{uid}/memories/{memoryId} (Memory)
    // Collection: /users/{uid}/summaries/{summaryId} (DailySummary)
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid']) &&
             data.uid is string &&
             (!('habits' in data) || data.habits is list) &&
             (!('goals' in data) || data.goals is list);
    }

    function isValidMemory(data) {
      return data.keys().hasAll(['uid', 'content', 'timestamp']) &&
             data.uid is string &&
             data.content is string &&
             data.content.size() < 5000 &&
             (!('embedding' in data) || data.embedding is list);
    }

    function isValidSummary(data) {
      return data.keys().hasAll(['uid', 'date', 'summary']) &&
             data.uid is string &&
             data.date is string &&
             data.summary is string;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUserProfile(request.resource.data);

      match /memories/{memoryId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidMemory(request.resource.data);
        allow update: if isOwner(userId) && isValidMemory(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /summaries/{summaryId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidSummary(request.resource.data);
      }
    }
  }
}
